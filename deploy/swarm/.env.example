# Example environment configuration for multi-node Swarm deployment
# Copy this file to .env and customize for your environment

# =============================================================================
# REQUIRED: Docker Socket Proxy Endpoints
# =============================================================================
# Comma-separated list of docker-socket-proxy endpoints for all nodes
# Each proxy runs on its respective node IP at port 2375
# 
# Example for 4-node Swarm (1 manager, 3 workers):
# DOCKER_ENDPOINTS=http://manager.mycorp.local:2375,http://worker-1.mycorp.local:2375,http://worker-2.mycorp.local:2375,http://worker-3.mycorp.local:2375
#
# Or using IPs:
# DOCKER_ENDPOINTS=http://10.0.0.11:2375,http://10.0.0.12:2375,http://10.0.0.13:2375,http://10.0.0.14:2375
DOCKER_ENDPOINTS=http://node1.local:2375,http://node2.local:2375,http://node3.local:2375,http://node4.local:2375

# =============================================================================
# OPTIONAL: Lilypad Configuration
# =============================================================================

# Hostname for Lilypad (used by Traefik routing)
# This is the URL users will access
LILYPAD_HOST=lilypad.mycorp.local

# Namespace for container labels
# Lilypad will only show containers with this label prefix
# Default: org.domain.review
# NAMESPACE=org.domain.review

# =============================================================================
# OPTIONAL: Network Configuration
# =============================================================================

# Name of the Docker overlay network (if different from default)
# DOCKER_NETWORK_NAME=swarm_docker-proxy

# Name of the Traefik network (if different from default)
# TRAEFIK_NETWORK_NAME=traefik-public
